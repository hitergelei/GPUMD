# LAMMPS GCMC with Umbrella Sampling - Reference for GPUMD validation
# Uses fix gcmc/umbrella for direct comparison with CUDA GCMC implementation

# Initialization
units           metal
dimension       3
boundary        p p p
atom_style      atomic

# Read initial structure
read_data       initial_structure.data

# Potential setup - Lennard-Jones
pair_style      lj/cut 12.0
pair_coeff      1 1  0.0103  3.405   # Ar-Ar 
pair_coeff      1 2  0.0067  3.190   # Ar-C
pair_coeff      2 2  0.0024  3.400   # C-C

# Groups
group           carbon type 2
group           argon type 1
group           mobile type 1

# Thermodynamic output
thermo_style    custom step temp press density atoms c_umbrella_bias
thermo          100

# Variables for umbrella GCMC
variable        temp equal 300.0
variable        mu equal -5.2        # Chemical potential (eV)
variable        disp equal 0.1       # Max displacement
variable        target equal 50      # Target number of Ar atoms
variable        k_spring equal 0.5   # Umbrella force constant (eV)

# Define umbrella bias compute
compute         umbrella_bias mobile coord 1

# Umbrella GCMC fix - matches GPUMD implementation
fix             gcmc mobile gcmc/umbrella 1 100 100 0 12345 ${temp} ${mu} ${disp} &
                target ${target} kappa ${k_spring}
fix_modify      gcmc atom_type 1

# Neighbor settings
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

# Output files
dump            1 all custom 1000 umbrella_dump.lammpstrj id type x y z
dump_modify     1 sort id

# Log umbrella sampling statistics
fix             umbrella_log all ave/time 10 10 100 c_umbrella_bias &
                file umbrella_statistics.out

# Variable for tracking
variable        n_ar equal "count(mobile)"
fix             n_atoms all ave/time 1 1 100 v_n_ar file n_atoms.out

# Run simulation
timestep        1.0
run             10000

# Output final state
print "Final Ar atoms: $(count(mobile))"
print "Average umbrella bias: $(f_umbrella_log)"

write_data      final_umbrella.data
