LAMMPS (29 Aug 2024 - Update 3)
# LAMMPS GCMC Input for Te-Pb System - Reference Validation
# Based on /home/hjchen/software/GPUMD_dev_wsl/GPUMD/src/GCMC/lammps/in.lammps.eV
# Modified for Te-Pb system to match GPUMD validation

units metal
atom_style atomic
dimension 3
boundary p p p

# Read initial structure
read_data initial_structure.data
Reading data file ...
  triclinic box = (0 0 0) to (23.229847 20.117638 18.967091) with tilt (11.614924 11.614924 6.7058793)
WARNING: Triclinic box skew is large. LAMMPS will run inefficiently. (../domain.cpp:221)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  250 atoms
  read_data CPU = 0.000 seconds

# Get box information first
variable xlo equal xlo
variable xhi equal xhi
variable ylo equal ylo
variable yhi equal yhi
variable zlo equal zlo
variable zhi equal zhi

# Define region with small margins to ensure it's within the box
region whole block ${xlo} ${xhi} ${ylo} ${yhi} ${zlo} ${zhi}
region whole block 0 ${xhi} ${ylo} ${yhi} ${zlo} ${zhi}
region whole block 0 23.2298474389351 ${ylo} ${yhi} ${zlo} ${zhi}
region whole block 0 23.2298474389351 0 ${yhi} ${zlo} ${zhi}
region whole block 0 23.2298474389351 0 20.1176380081547 ${zlo} ${zhi}
region whole block 0 23.2298474389351 0 20.1176380081547 0 ${zhi}
region whole block 0 23.2298474389351 0 20.1176380081547 0 18.9670910093632

# Simple LJ potential for Te-Pb (placeholder - would need NEP equivalent)
# Note: These parameters are approximations for validation purposes
pair_style lj/cut 12.0
pair_coeff 1 1 0.0103 3.405 12.0  # Te-Te
pair_coeff 1 2 0.0067 3.195 12.0  # Te-Pb
pair_coeff 2 2 0.0024 3.400 12.0  # Pb-Pb
pair_modify shift yes

# Initialize velocities for initial equilibration
velocity all create 300.0 4928459 rot yes dist gaussian

# Check initial system
variable initial_atoms equal atoms
variable box_volume equal vol
print "Initial atoms: ${initial_atoms}"
Initial atoms: 250
print "Box volume: ${box_volume} A^3"
Box volume: 8863.88422599881 A^3

# Define groups (Te=type 1, Pb=type 2)
group tellurium type 1
125 atoms in group tellurium
group lead type 2
125 atoms in group lead
group mobile type 2    # Only Pb atoms are mobile for GCMC
125 atoms in group mobile

# Neighbor list
neighbor 2.0 bin
neigh_modify every 1 delay 0 check yes

# Thermodynamic output
thermo_style custom step temp press density atoms pe ke etotal
thermo 10

# GCMC fix - matching GPUMD parameters
# Temperature: 300K, Chemical potential: -2.0 eV for Pb
# Displacement: 1.0 Angstrom (GPUMD default)
variable temp equal 300.0
variable mu equal -2.0
variable disp equal 1.0

# GCMC fix: attempts every 1 step, 100 exchange, 100 displacement moves
# Only operate on Pb atoms (type 2)
# Syntax: fix ID group-ID gcmc N X M type seed T mu displace keyword values
fix gcmc_fix mobile gcmc 1 100 100 2 12345 ${temp} ${mu} ${disp} region whole
fix gcmc_fix mobile gcmc 1 100 100 2 12345 300 ${mu} ${disp} region whole
fix gcmc_fix mobile gcmc 1 100 100 2 12345 300 -2 ${disp} region whole
fix gcmc_fix mobile gcmc 1 100 100 2 12345 300 -2 1 region whole

# Brief equilibration before main run
fix nvt_equil all nvt temp ${temp} ${temp} 0.1
fix nvt_equil all nvt temp 300 ${temp} 0.1
fix nvt_equil all nvt temp 300 300 0.1
run 10
Generated 0 of 1 mixed pair_coeff terms from geometric mixing rule
