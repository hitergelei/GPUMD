variable final_atoms equal atoms
variable final_density equal density
variable final_volume equal vol
print "Final atoms: ${final_atoms}"
Final atoms: 192
print "Final density: ${final_density}"
Final density: 5.5887306337441
print "Final volume: ${final_volume} A^3"
Final volume: 8863.88422599881 A^3

# Count atoms by type
group te_final type 1
125 atoms in group te_final
group pb_final type 2
67 atoms in group pb_final
variable n_te equal count(te_final)
variable n_pb equal count(pb_final)
print "Final Te atoms: ${n_te}"
Final Te atoms: 125
print "Final Pb atoms: ${n_pb}"
Final Pb atoms: 67

write_data final_lammps.data
